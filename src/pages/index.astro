---
import Layout from '../layouts/Layout.astro';
import PostList from '../components/PostList.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles');
const sorted = allArticles.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const latest = sorted.slice(0, 5);
const seriesCount = allArticles.filter(a => a.data.tags.includes('architects-mindset')).length;
---

<Layout title="Home" description="A curious engineer's notebook on the internet. Systems, architecture, databases, AI — and the ideas worth understanding before you need them.">

  <!-- Hero -->
  <section class="pt-4 pb-10 sm:pb-16 border-b border-white/[0.06] max-w-2xl">
    <div class="inline-flex items-center gap-2 text-[10px] text-cyan-400 border border-cyan-400/30 bg-cyan-400/[0.05] px-3 py-1.5 mb-3 tracking-[0.25em] uppercase rounded-full font-mono-brand">
      <span class="w-1.5 h-1.5 rounded-full bg-cyan-400 shrink-0"></span>
      LEARNING IN PUBLIC
    </div>

    <h1 class="font-mono-brand font-extrabold text-white text-4xl sm:text-5xl lg:text-6xl leading-[1.1] tracking-tight mb-5 sm:mb-8">
      Learn before you<br/>
      <span class="text-cyan-400">need</span> it.
    </h1>

    <div class="mb-6 sm:mb-10 space-y-3 sm:space-y-5 text-sm sm:text-base">
      <div class="space-y-1 font-mono-brand">
        <p class="text-slate-300">AI can write code.</p>
        <p class="text-white font-semibold">Humans still make decisions.</p>
      </div>
      <p class="text-slate-400 leading-relaxed">
        Hi, I'm <strong class="text-white font-medium">Navneet R. Mahajan</strong> — learning in public, documenting each thing, one rabbit hole at a time.
      </p>
      <p class="text-cyan-400/80 font-mono-brand text-xs tracking-widest uppercase">Because curiosity compounds.</p>
      <p class="text-slate-500 text-sm leading-relaxed">
        Just curiosity, experiments, mistakes, and notes from the journey.
      </p>
    </div>

    <p class="text-slate-600 text-xs font-mono-brand mb-4 sm:mb-6">No mentor. No plan. Learning it anyway.</p>

    <div class="flex flex-col sm:flex-row items-start sm:items-center gap-3 sm:gap-4">
      <a
        href="/articles/2026-06-21-architects-mindset-day-0"
        class="font-mono-brand text-xs tracking-[0.12em] uppercase bg-cyan-400 text-black font-bold px-7 py-3.5 hover:bg-cyan-300 transition-colors w-full sm:w-auto text-center"
      >
        Start with Day 0 →
      </a>
      <a
        href="/articles"
        class="font-mono-brand text-xs tracking-[0.12em] uppercase border border-white/15 text-slate-300 px-7 py-3.5 hover:border-white/40 hover:text-white transition-colors w-full sm:w-auto text-center"
      >
        Browse Articles
      </a>
    </div>
  </section>

  <!-- Series Spotlight -->
  <section class="py-10 sm:py-14 border-b border-white/[0.06]">
    <div class="flex items-start gap-5">
      <div class="w-px self-stretch bg-cyan-400 shrink-0"></div>
      <div>
        <p class="text-[10px] tracking-[0.2em] uppercase text-cyan-400/60 mb-2 font-mono-brand">Currently Writing</p>
        <h2 class="text-white font-extrabold text-xl sm:text-2xl font-mono-brand mb-3">The Architect's Mindset</h2>
        <p class="text-slate-400 text-sm leading-relaxed max-w-xl mb-6">
          50 topics across 4 milestones — the decisions behind how modern software systems are designed, deployed, and scaled.
          Not tutorials. Not theory. Just the trade-offs engineers actually face, explained one concept at a time.
        </p>
        <div class="flex flex-wrap items-center gap-4 sm:gap-6">
          <span class="text-slate-600 text-xs font-mono-brand">{seriesCount} of 50 published</span>
          <a href="/roadmap" class="text-xs font-mono-brand text-cyan-400 hover:text-cyan-300 transition-colors">View Roadmap →</a>
          <a href="/articles/2026-06-21-architects-mindset-day-0" class="text-xs font-mono-brand text-slate-500 hover:text-white transition-colors">Start from Day 0 →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Latest Articles -->
  <section class="pt-10 sm:pt-14">
    <div class="flex items-center justify-between mb-2">
      <h2 class="text-white font-bold text-xl font-mono-brand">Latest articles</h2>
      <a
        href="/articles"
        class="text-[11px] tracking-[0.15em] uppercase text-slate-500 hover:text-white transition-colors"
      >
        All Articles →
      </a>
    </div>
    <p class="text-slate-600 text-xs font-mono-brand mb-8">
      New here? <a href="/articles/2026-06-21-architects-mindset-day-0" class="text-cyan-400/70 hover:text-cyan-400 transition-colors">Start with Day 0 →</a>
    </p>
    <PostList posts={latest} />
  </section>

</Layout>
